# Copie um dos perfis abaixo para .env dependendo do ambiente:
#
# Desenvolvimento local (Docker):
#   cp backend/.env.docker backend/.env
#
# Produção (Supabase):
#   cp backend/.env.supabase backend/.env
#   (substitua [YOUR-PASSWORD] pela senha real do Supabase)

# ── Docker (local) ────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sia_gestor
# HOST=0.0.0.0
# PORT=3001

# ── Supabase (produção) ───────────────────────────────────────────────────────
# SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# SUPABASE_ANON_KEY=<ANON_KEY>
# DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# HOST=0.0.0.0
# PORT=3001
