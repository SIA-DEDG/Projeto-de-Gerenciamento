<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>SIA Gestão - Gerenciamento de Projetos</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Sistema de Gerenciamento de Projetos da Secretaria de Inteligência Artificial">
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/assets/application.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/sortable.min.js"></script>
    <script src="/store.js"></script>
  </head>
  <body>
    <div class="app-container">
      <aside class="sidebar">
        <div class="logo">
          <div class="logo-icon">SIA</div>
          <div class="logo-text">
            <span class="logo-title">SIA Gestão</span>
            <span class="logo-subtitle">Portfólio de Projetos</span>
          </div>
        </div>

        <div class="sidebar-divider"></div>

        <div class="sidebar-section">
          <div class="sidebar-section-title">Planejamento</div>
          <ul class="nav">
            <li class="<%= current_page?(root_path) ? 'active' : '' %>">
              <%= link_to root_path, class: 'nav-link' do %>
                <span class="nav-icon">
                  <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                </span>
                Board
              <% end %>
            </li>
            <li class="<%= current_page?(metrics_path) ? 'active' : '' %>">
              <%= link_to metrics_path, class: 'nav-link' do %>
                <span class="nav-icon">
                  <svg viewBox="0 0 24 24"><path d="M18 20V10"></path><path d="M12 20V4"></path><path d="M6 20v-6"></path></svg>
                </span>
                Dashboards
              <% end %>
            </li>
            <li class="<%= current_page?(reports_path) ? 'active' : '' %>">
              <%= link_to reports_path, class: 'nav-link' do %>
                <span class="nav-icon">
                  <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </span>
                Relatórios
              <% end %>
            </li>
          </ul>
        </div>

        <div class="sidebar-divider"></div>

        <div class="sidebar-section">
          <div class="sidebar-section-title">Configuração</div>
          <ul class="nav">
            <li>
              <span class="nav-link" id="nav-config" style="cursor: pointer;">
                <span class="nav-icon">
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                </span>
                Configurações
              </span>
            </li>
          </ul>
        </div>

        <div class="sidebar-footer">
          <div class="sidebar-user">
            <div class="sidebar-avatar">IA</div>
            <div class="sidebar-user-info">
              <span class="sidebar-user-name">Equipe SIA</span>
              <span class="sidebar-user-role">Administrador</span>
            </div>
          </div>
        </div>
      </aside>

      <main class="main-content">
        <header class="topbar">
          <div class="topbar-left">
            <h1><%= content_for?(:page_title) ? yield(:page_title) : 'Board' %></h1>
          </div>
          <div class="topbar-right">
            <div class="topbar-search">
              <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
              <input type="text" placeholder="Pesquisar atividades...">
            </div>
            <div class="user-profile">
              <span class="avatar" title="Equipe SIA">IA</span>
            </div>
          </div>
        </header>

        <%= yield %>
      </main>

      <div id="settings-modal" class="settings-modal-backdrop" style="display: none;">
        <div class="settings-modal-card">
          <div class="settings-modal-head">
            <h3>Configurações do Sistema</h3>
            <button type="button" class="settings-close-btn" onclick="document.getElementById('settings-modal').style.display='none'">&times;</button>
          </div>
          <p class="settings-modal-subtitle">Defina padrões operacionais do ambiente e preferências da equipe.</p>

          <form id="settings-form" class="settings-form-grid">
            <label class="settings-label">
              Tema da Interface
              <select id="settings-theme">
                <option value="claro">Claro</option>
                <option value="escuro">Escuro</option>
              </select>
            </label>

            <label class="settings-label">
              Perfil de Notificação
              <select id="settings-notification-profile">
                <option value="completo">Completo</option>
                <option value="somente_critico">Somente crítico</option>
                <option value="silencioso">Silencioso</option>
              </select>
            </label>

            <label class="settings-label">
              Canal de Alertas
              <select id="settings-alert-channel">
                <option value="email">Email</option>
                <option value="in_app">No sistema</option>
                <option value="email_e_sistema">Email + sistema</option>
              </select>
            </label>

            <label class="settings-label">
              Atualização Automática
              <select id="settings-refresh">
                <option value="5">A cada 5 minutos</option>
                <option value="15">A cada 15 minutos</option>
                <option value="30">A cada 30 minutos</option>
                <option value="manual">Manual</option>
              </select>
            </label>

            <label class="settings-toggle">
              <input type="checkbox" id="settings-email-enabled" checked>
              <span>Habilitar notificações por email</span>
            </label>

            <div class="settings-form-actions">
              <button type="submit" class="btn-primary">Salvar Alterações</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const SETTINGS_KEY = 'sia_system_settings_v1';
        const configBtn = document.getElementById('nav-config');
        const settingsModal = document.getElementById('settings-modal');
        const settingsForm = document.getElementById('settings-form');

        function loadSettings() {
          const raw = localStorage.getItem(SETTINGS_KEY);
          if (!raw) return;
          const settings = JSON.parse(raw);
          document.getElementById('settings-theme').value = settings.theme || 'claro';
          document.getElementById('settings-notification-profile').value = settings.notificationProfile || 'completo';
          document.getElementById('settings-alert-channel').value = settings.alertChannel || 'email';
          document.getElementById('settings-refresh').value = settings.refreshInterval || '15';
          document.getElementById('settings-email-enabled').checked = settings.emailEnabled !== false;
        }

        function saveSettings(event) {
          event.preventDefault();
          const payload = {
            theme: document.getElementById('settings-theme').value,
            notificationProfile: document.getElementById('settings-notification-profile').value,
            alertChannel: document.getElementById('settings-alert-channel').value,
            refreshInterval: document.getElementById('settings-refresh').value,
            emailEnabled: document.getElementById('settings-email-enabled').checked
          };
          localStorage.setItem(SETTINGS_KEY, JSON.stringify(payload));
          settingsModal.style.display = 'none';
          alert('Configurações salvas com sucesso.');
        }

        if (configBtn) {
          configBtn.addEventListener('click', () => {
            loadSettings();
            settingsModal.style.display = 'flex';
          });
        }

        if (settingsForm) {
          settingsForm.addEventListener('submit', saveSettings);
        }
      });
    </script>
  </body>
</html>
