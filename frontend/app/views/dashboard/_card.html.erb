<% task_date = "2026-04-#{format('%02d', rand(1..30))}" %>
<div class="kanban-card" style="position: relative; padding-left: 28px; margin-bottom: 12px; min-height: 90px;" data-responsible="<%= task['responsible'] %>" data-date="<%= task_date %>" onclick="openTaskModal(this)">
  <!-- Aba lateral para arrastar -->
  <div class="drag-handle" onclick="event.stopPropagation()" style="position: absolute; left: 0; top: 0; bottom: 0; width: 14px; background: #e0e6ed; border-radius: 8px 0 0 8px; cursor: grab; display: flex; align-items: center; justify-content: center; color: #a1aeb7;">
    <svg viewBox="0 0 24 24" width="10" height="20" stroke="currentColor" fill="currentColor">
      <circle cx="9" cy="5" r="1.5"></circle><circle cx="15" cy="5" r="1.5"></circle>
      <circle cx="9" cy="12" r="1.5"></circle><circle cx="15" cy="12" r="1.5"></circle>
      <circle cx="9" cy="19" r="1.5"></circle><circle cx="15" cy="19" r="1.5"></circle>
    </svg>
  </div>
  
  <div class="card-content">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">
      <p class="card-title" style="flex: 1; word-wrap: break-word;"><%= task["activity"] %></p>
      <button class="delete-card-btn" title="Excluir" onclick="event.stopPropagation(); this.closest('.kanban-card').remove(); if (window.updateColumnCounts) window.updateColumnCounts();" style="background: none; border: none; cursor: pointer; color: #a1aeb7; margin-top: 2px; flex-shrink: 0;">
        <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
      </button>
    </div>
    <div class="badge-wrapper">
      <span class="jira-badge <%= badge_class %>"><%= task["category"] %></span>
    </div>
  </div>
  
  <div class="card-footer" style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
    <span class="issue-key">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
        <line x1="4" y1="22" x2="4" y2="15"></line>
      </svg>
      SIA-<%= task["id"] || rand(100..400) %>
    </span>
    
    <div style="display: flex; align-items: center; gap: 8px;">
      <span class="card-date" style="font-size: 0.75rem; color: #6b778c; display: flex; align-items: center; gap: 4px;">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        <span class="date-val"><%= task_date %></span>
      </span>
      <div class="avatar-group">
        <% if task["responsible"] %>
          <div class="jira-avatar" style="background-color: <%= avatar_color_for(task["responsible"]) %>" title="<%= task["responsible"] %>">
            <%= initials_for(task["responsible"]) %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
