<% content_for(:page_title, "Dashboards") %>

<div class="page-content">
  <div class="dashboard-header">
    <h2>Visão Geral do Portfólio</h2>
    <p class="subtitle">Acompanhamento de status e métricas-chave dos projetos da SIA.</p>
  </div>

  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-icon pending-icon"></div>
      <div class="metric-info">
        <h3>Pendentes</h3>
        <div class="metric-value"><%= @pending_count %></div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon progress-icon"></div>
      <div class="metric-info">
        <h3>Em Andamento</h3>
        <div class="metric-value"><%= @in_progress_count %></div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon done-icon"></div>
      <div class="metric-info">
        <h3>Concluídos</h3>
        <div class="metric-value"><%= @completed_count %></div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon total-icon"></div>
      <div class="metric-info">
        <h3>Total de Atividades</h3>
        <div class="metric-value"><%= @total_count %></div>
      </div>
    </div>
  </div>

  <div class="charts-container">
    <div class="chart-card">
      <h3>Distribuição de Status</h3>
      <div class="chart-wrapper">
        <canvas id="statusChart"></canvas>
      </div>
    </div>
    <div class="chart-card">
      <h3>Atividades por Projeto</h3>
      <div class="chart-wrapper">
        <canvas id="categoryChart"></canvas>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const ctx1 = document.getElementById("statusChart").getContext("2d");
    new Chart(ctx1, {
      type: "doughnut",
      data: {
        labels: ["Pendentes", "Em Andamento", "Concluídos"],
        datasets: [{
          data: [<%= @pending_count %>, <%= @in_progress_count %>, <%= @completed_count %>],
          backgroundColor: ["#DFE1E6", "#DEEBFF", "#E3FCEF"],
          borderColor: ["#B3BAC5", "#4C9AFF", "#57D9A3"],
          borderWidth: 2,
          hoverOffset: 8
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: "65%",
        plugins: {
          legend: {
            position: "bottom",
            labels: {
              padding: 16,
              usePointStyle: true,
              pointStyleWidth: 10,
              font: { family: "'Inter', sans-serif", size: 12, weight: "500" }
            }
          }
        }
      }
    });

    const ctx2 = document.getElementById("categoryChart").getContext("2d");
    const catLabels = <%= raw @categories.map { |c| c[:name] }.to_json %>;
    const catData = <%= raw @categories.map { |c| c[:count] }.to_json %>;
    const barColors = ["#0052CC", "#00B8D9", "#FF991F", "#00875A", "#6554C0", "#DE350B", "#FFAB00"];

    new Chart(ctx2, {
      type: "bar",
      data: {
        labels: catLabels,
        datasets: [{
          label: "Atividades",
          data: catData,
          backgroundColor: barColors.slice(0, catLabels.length),
          borderRadius: 6,
          borderSkipped: false,
          barThickness: 32
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        indexAxis: "y",
        scales: {
          x: {
            beginAtZero: true,
            ticks: { stepSize: 1, font: { family: "'Inter', sans-serif", size: 11 } },
            grid: { color: "rgba(0,0,0,0.04)" }
          },
          y: {
            ticks: { font: { family: "'Inter', sans-serif", size: 12, weight: "500" } },
            grid: { display: false }
          }
        },
        plugins: { legend: { display: false } }
      }
    });
  });
</script>
