generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Directoria {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String        @unique
  description     String?
  color           String?
  active          Boolean       @default(true)
  autoArchiveDays Int           @default(2) @map("auto_archive_days")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  absences        Absence[]
  activityLogs    ActivityLog[]
  events          Event[]
  projects        Project[]
  tasks           Task[]
  members         User[]

  @@map("diretorias")
}

model User {
  id                      String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  username                String               @unique
  passwordHash            String               @map("password_hash")
  role                    String               @default("Funcionario")
  mustChangePassword      Boolean              @default(true) @map("must_change_password")
  createdAt               DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  directoriaId            String?              @map("directoria_id") @db.Uuid
  absences                Absence[]
  activityLogs            ActivityLog[]
  eventResponsibles       EventResponsible[]
  feedbackUpvotes         FeedbackUpvote[]
  feedbacks               Feedback[]
  ownedProjects           Project[]
  projectResponsibilities ProjectResponsible[]
  taskPins                TaskPin[]
  coResponsibilities      TaskCoResponsible[]
  tasks                   Task[]               @relation("responsible")
  directoria              Directoria?          @relation(fields: [directoriaId], references: [id], onUpdate: NoAction)

  @@index([directoriaId])
  @@map("users")
}

model Project {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  category        String?
  deadline        DateTime?            @db.Date
  executiveStatus String?              @map("executive_status")
  objective       String?
  scope           String?
  summary         String?
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  ownerId         String?              @map("owner_id") @db.Uuid
  directoriaId    String               @map("directoria_id") @db.Uuid
  attachments     String?
  directoria      Directoria           @relation(fields: [directoriaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  owner           User?                @relation(fields: [ownerId], references: [id], onUpdate: NoAction)
  responsibles    ProjectResponsible[]
  tasks           Task[]

  @@index([directoriaId])
  @@map("projects")
}

model ProjectResponsible {
  projectId String  @map("project_id") @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([projectId, userId])
  @@index([userId], map: "idx_project_responsibles_user_id")
  @@map("project_responsibles")
}

model Task {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category              String
  activity              String
  status                String
  priority              String              @default("Média")
  createdAt             DateTime            @default(dbgenerated("CURRENT_DATE")) @map("created_at") @db.Date
  description           String?
  projectId             String?             @map("project_id") @db.Uuid
  externalCollaborators String?             @map("external_collaborators")
  responsibleId         String?             @map("responsible_id") @db.Uuid
  deadline              DateTime?           @db.Date
  archived              Boolean             @default(false)
  directoriaId          String              @map("directoria_id") @db.Uuid
  attachments           String?
  updatedAt             DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  evidences             evidences[]
  pins                  TaskPin[]
  coResponsibles        TaskCoResponsible[]
  directoria            Directoria          @relation(fields: [directoriaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  project               Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  responsible           User?               @relation("responsible", fields: [responsibleId], references: [id], onUpdate: NoAction)

  @@index([archived])
  @@index([directoriaId])
  @@index([category], map: "idx_tasks_category")
  @@index([responsibleId], map: "idx_tasks_responsible_id")
  @@index([status], map: "idx_tasks_status")
  @@map("tasks")
}

model TaskCoResponsible {
  taskId String @map("task_id") @db.Uuid
  userId String @map("user_id") @db.Uuid
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([taskId, userId])
  @@index([taskId], map: "idx_tcr_task_id")
  @@map("task_co_responsibles")
}

model TaskPin {
  taskId    String   @map("task_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([taskId, userId])
  @@index([userId], map: "idx_task_pins_user_id")
  @@map("task_pins")
}

model Absence {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reason         String
  justification  String?
  fileName       String?    @map("file_name")
  file_data      String?
  startDate      DateTime   @map("start_date") @db.Date
  endDate        DateTime   @map("end_date") @db.Date
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  userId         String?    @map("user_id") @db.Uuid
  approvalStatus String     @default("pendente") @map("approval_status")
  filePath       String?    @map("file_path")
  directoriaId   String     @map("directoria_id") @db.Uuid
  directoria     Directoria @relation(fields: [directoriaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           User?      @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([directoriaId])
  @@index([startDate], map: "idx_absences_start")
  @@index([userId], map: "idx_absences_user_id")
  @@map("absences")
}

model Event {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  eventType       String             @map("event_type")
  attendees       String?
  startDate       DateTime           @map("start_date") @db.Date
  endDate         DateTime           @map("end_date") @db.Date
  startTime       String?            @map("start_time")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  archived        Boolean            @default(false)
  minutesFileName String?            @map("minutes_file_name")
  minutesFilePath String?            @map("minutes_file_path")
  attachments     String?
  directoriaId    String             @map("directoria_id") @db.Uuid
  responsibles    EventResponsible[]
  directoria      Directoria         @relation(fields: [directoriaId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([archived])
  @@index([directoriaId])
  @@index([startDate], map: "idx_events_start")
  @@map("events")
}

model EventResponsible {
  eventId String @map("event_id") @db.Uuid
  userId  String @map("user_id") @db.Uuid
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([eventId, userId])
  @@index([eventId], map: "idx_er_event_id")
  @@map("event_responsibles")
}

model Feedback {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipo             String
  titulo           String
  descricao        String
  severidade       String?
  usuarioId        String?           @map("usuario_id") @db.Uuid
  usuarioNome      String?           @map("usuario_nome")
  usuarioDiretoria String?           @map("usuario_diretoria")
  imagens          String?
  resposta         String?
  status           String            @default("pendente")
  // Aviso "sua sugestão foi respondida" já mostrado ao autor (por usuário, no banco —
  // some de vez em qualquer dispositivo, diferente do antigo controle por localStorage).
  replySeen        Boolean           @default(false) @map("reply_seen")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  comments         FeedbackComment[]
  upvotes          FeedbackUpvote[]
  usuario          User?             @relation(fields: [usuarioId], references: [id], onUpdate: NoAction)

  @@index([createdAt])
  @@map("feedbacks")
}

model FeedbackUpvote {
  feedbackId String   @map("feedback_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([feedbackId, userId])
  @@map("feedback_upvotes")
}

model FeedbackComment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feedbackId  String   @map("feedback_id") @db.Uuid
  parentId    String?  @map("parent_id") @db.Uuid
  usuarioId   String?  @map("usuario_id") @db.Uuid
  usuarioNome String   @default("An?nimo") @map("usuario_nome")
  conteudo    String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  feedback    Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([feedbackId], map: "feedback_comments_feedback_idx")
  @@map("feedback_comments")
}

model ActivityLog {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  userName     String      @map("user_name")
  action       String
  entityType   String      @map("entity_type")
  entityId     String      @map("entity_id")
  details      String      @default("")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  directoriaId String?     @map("directoria_id") @db.Uuid
  directoria   Directoria? @relation(fields: [directoriaId], references: [id], onUpdate: NoAction)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([directoriaId])
  @@index([createdAt(sort: Desc)], map: "idx_logs_created_at")
  @@index([entityType], map: "idx_logs_entity_type")
  @@index([userId], map: "idx_logs_user_id")
  @@map("activity_logs")
}

model sqlx_migrations {
  version        BigInt   @id
  description    String
  installed_on   DateTime @default(now()) @db.Timestamptz(6)
  success        Boolean
  checksum       Bytes
  execution_time BigInt

  @@map("_sqlx_migrations")
}

model evidences {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id      String   @db.Uuid
  file_name    String
  file_type    String?
  note         String?
  storage_path String?
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  tasks        Task     @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([task_id], map: "idx_evidences_task_id")
}
